{
  "name": "esusustellar",
  "version": "2.0.0",
  "description": "EsusuStellar — Decentralized Rotating Savings & Credit Association (ROSCA) on Stellar Soroban. Trustless, transparent, on-chain savings circles.",
  "author": "Sayo-codes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sayo-codes/EsusuStellar"
  },
  "keywords": [
    "stellar",
    "soroban",
    "rust",
    "defi",
    "rosca",
    "esusu",
    "savings",
    "blockchain",
    "web3",
    "smart-contracts",
    "freighter"
  ],
  "scripts": {
    "contract:build": "stellar contract build",
    "contract:test": "cd contracts/soroban/esusu_pool && cargo test",
    "contract:optimize": "stellar contract optimize --wasm contracts/soroban/esusu_pool/target/wasm32-unknown-unknown/release/esusu_pool.wasm",
    "contract:deploy:testnet": "stellar contract deploy --wasm contracts/soroban/esusu_pool/target/wasm32-unknown-unknown/release/esusu_pool.optimized.wasm --source deployer --network testnet",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "lint": "cd contracts/soroban/esusu_pool && cargo clippy -- -D warnings"
  },
  "devDependencies": {
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.0.0",
    "dotenv": "^16.0.0"
  }
}
