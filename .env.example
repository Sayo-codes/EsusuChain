# Environment Configuration — EsusuChain (Stellar / Soroban)
# Copy this to .env and fill in your values. NEVER commit your .env file.

# ─── Stellar CLI Identity ───────────────────────────────────────────────────
# Name of your Stellar CLI key identity (created with: stellar keys generate --global deployer --network testnet)
STELLAR_DEPLOYER_KEY=deployer

# ─── Network ────────────────────────────────────────────────────────────────
# "testnet" or "mainnet"
STELLAR_NETWORK=testnet

# ─── RPC Endpoints ─────────────────────────────────────────────────────────
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ─── Deployed Contract ──────────────────────────────────────────────────────
# Set this after deploying: stellar contract deploy ...
# CONTRACT_ID=C...

# ─── Token (Stellar Asset Contract) ────────────────────────────────────────
# The SAC address of the token used for contributions (e.g. wrapped XLM or USDC)
# TOKEN_ADDRESS=C...

# ─── Frontend ───────────────────────────────────────────────────────────────
VITE_CONTRACT_ID=
VITE_STELLAR_NETWORK=testnet
VITE_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
